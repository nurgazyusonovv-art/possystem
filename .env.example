# Supabase долбооруңуздун маалыматтары (Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Сайттын ДАРЕГИ — QR коддору ушуну колдонот.
# Локалда: http://localhost:3000
# Продакшнда: https://сиздин-домен.com  (МИЛДЕТТҮҮ туура коюлсун!)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ===== Онлайн төлөм (PayBox.money) — милдеттүү эмес =====
# QR менюда "Онлайн төлөө" баскычын көрсөтүү (1 = күйөт)
NEXT_PUBLIC_ONLINE_PAYMENT=0
# PayBox merchant маалыматтары (СЕРВЕР гана — NEXT_PUBLIC ЭМЕС!)
PAYBOX_MERCHANT_ID=
PAYBOX_SECRET_KEY=
PAYBOX_TESTING_MODE=1
# Webhook DB'ге жазат — Supabase service role ачкычы (СЕРВЕР гана!)
SUPABASE_SERVICE_ROLE_KEY=
